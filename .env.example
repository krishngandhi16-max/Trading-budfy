# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/trading_budfy

# ── Phase 3: Broker integration ───────────────────────────────────────────────
# Set BROKER_ENABLED=true ONLY in production/paper-live environments.
# All broker API calls are no-ops when this is false or unset.
BROKER_ENABLED=false

# Alpaca (paper trading — always uses paper-api.alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_id
ALPACA_API_SECRET=your_alpaca_secret_key

# Oanda (practice — always uses api-fxpractice.oanda.com)
OANDA_API_KEY=your_oanda_personal_access_token
OANDA_ACCOUNT_ID=001-001-0000000-001

# Optional: override sync interval in ms (default 300000 = 5 min)
# SYNC_INTERVAL_MS=300000
